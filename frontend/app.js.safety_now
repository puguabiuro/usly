  window.USLY_API_BASE_URL ||
  (location.hostname.includes("onrender.com")
    ? "https://usly-backend-v2.onrender.com"
    : "http://127.0.0.1:8000");

// expose for api.js (plain scripts)
window.API_BASE_URL = API_BASE_URL;


