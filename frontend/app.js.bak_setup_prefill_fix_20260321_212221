    if (typeEl) typeEl.textContent = "Płatne — przedział";
    if (pricePill) pricePill.textContent = `${ev.priceFrom}–${ev.priceTo} zł`;
    if (lineEl) lineEl.textContent = `Cena: ${ev.priceFrom}–${ev.priceTo} zł (zakup / rezerwacja poza aplikacją).`;
