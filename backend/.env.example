# Copy this file to .env and fill values
JWT_SECRET_KEY=

# Optional:
# PORT=8000

# Database (example)
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/usly

# Store purchase verification: leave empty in production until Apple/Google verification is implemented.
# Local test mode only: set to test when intentionally testing /store/verify-purchase.
STORE_PURCHASE_VERIFICATION_MODE=

# Deep links / mobile app links
# Production fallback web links should normally use https://uslyapp.pl/verify-email and https://uslyapp.pl/reset-password.
# Custom scheme links may be used for local/mobile testing: usly://verify-email and usly://reset-password.
EMAIL_VERIFY_LINK_BASE=
PASSWORD_RESET_LINK_BASE=
ANDROID_PACKAGE_NAME=com.usly.app
ANDROID_SHA256_CERT_FINGERPRINTS=
APPLE_TEAM_ID=
IOS_BUNDLE_ID=com.usly.app
