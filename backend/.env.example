# USLY backend environment example
# Copy this file to backend/.env locally and fill values.
# Never commit real secrets.

# -------------------------------------------------------------------
# Core
# -------------------------------------------------------------------

ENV=local
JWT_SECRET_KEY=
PORT=8000

# Database
# Local SQLite is used by default if DATABASE_URL is empty.
# Production should use Render PostgreSQL.
# Example:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/usly
DATABASE_URL=

# CORS / frontend origin
# Production:
# FRONTEND_ORIGIN=https://uslyapp.pl
FRONTEND_ORIGIN=

# -------------------------------------------------------------------
# Error monitoring
# -------------------------------------------------------------------

# Optional Sentry monitoring.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# -------------------------------------------------------------------
# Store purchase verification
# -------------------------------------------------------------------

# Leave empty in production until Apple/Google/RevenueCat verification is implemented.
# Local test mode only: set to test when intentionally testing /store/verify-purchase.
STORE_PURCHASE_VERIFICATION_MODE=

# -------------------------------------------------------------------
# Deep links / mobile app links
# -------------------------------------------------------------------

# Production fallback web links should normally use:
# EMAIL_VERIFY_LINK_BASE=https://uslyapp.pl/verify-email
# PASSWORD_RESET_LINK_BASE=https://uslyapp.pl/reset-password
#
# Custom scheme links may be used for local/mobile testing:
# EMAIL_VERIFY_LINK_BASE=usly://verify-email
# PASSWORD_RESET_LINK_BASE=usly://reset-password

EMAIL_VERIFY_LINK_BASE=
PASSWORD_RESET_LINK_BASE=

ANDROID_PACKAGE_NAME=com.usly.app
ANDROID_SHA256_CERT_FINGERPRINTS=

APPLE_TEAM_ID=
IOS_BUNDLE_ID=com.usly.app

# -------------------------------------------------------------------
# Firebase Admin SDK / Push notifications
# -------------------------------------------------------------------

# Base64-encoded Firebase service account JSON.
# Keep the real value only in backend/.env locally and Render Environment Variables.
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# -------------------------------------------------------------------
# Cloudflare R2 / media storage
# -------------------------------------------------------------------

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# -------------------------------------------------------------------
# Google Maps / Places
# -------------------------------------------------------------------

# Used by backend Google Places proxy.
GOOGLE_MAPS_API_KEY=

# -------------------------------------------------------------------
# OpenAI / AI avatar and moderation
# -------------------------------------------------------------------

# Used for AI avatar generation and content moderation.

OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=low
OPENAI_MODERATION_MODEL=gpt-4.1-mini

# -------------------------------------------------------------------
# SMTP / transactional emails
# -------------------------------------------------------------------

USLY_SMTP_HOST=
USLY_SMTP_PORT=587
USLY_SMTP_USER=
USLY_SMTP_PASS=
USLY_SMTP_FROM=
